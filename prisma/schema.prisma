generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationType {
  DATA_ACCESS_APPLICATION  // Full data permit – personal data in SPE
  DATA_REQUEST             // Art. 69 – anonymised/aggregated results
}

// States per TEHDAS2 D6.4 Figure 1 (Data Access Application State Machine Diagram)
// DRAFT is a pre-submission state not shown in the diagram but required by D6.4
enum ApplicationStatus {
  DRAFT                           // Applicant composing the form (pre-submission)
  SUBMITTED                       // Lodged with HDAB; statutory clock starts
  PRE_SCREENING                   // HDAB pre-screens the application for completeness
  AWAITING_ADDITIONAL_INFORMATION // HDAB requested additional info during pre-screening
  PROCESSING                      // HDAB substantively processes the application
  DECISION_ISSUED                 // HDAB has taken a decision (see decisionOutcome)
  WITHDRAWN                       // Withdrawn by applicant at any stage
}

// Sub-state of DECISION_ISSUED per TEHDAS2 Figure 1
enum DecisionOutcome {
  POSITIVE
  NEGATIVE
}

enum UserRole {
  APPLICANT
  CASE_HANDLER
  DECISION_MAKER
  DATA_HOLDER
  ADMIN
}

enum ApplicationSource {
  NATIONAL    // Submitted directly through HDAB-NL DAAMS
  HDEU        // Received via HealthData@EU NCP (cross-border)
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         UserRole
  organisation String
  createdAt    DateTime @default(now())

  applications    Application[]   @relation("Applicant")
  handledCases    Application[]   @relation("CaseHandler")
  auditLogs       AuditLog[]
  notes           Note[]
}

model Application {
  id              String            @id @default(cuid())
  referenceNumber String            @unique
  type            ApplicationType
  status          ApplicationStatus @default(DRAFT)
  source          ApplicationSource @default(NATIONAL)

  // Set when status = DECISION_ISSUED
  decisionOutcome DecisionOutcome?

  // For HD@EU cross-border applications
  hdeuApplicationId   String?
  hdeuSendingCountry  String?
  hdeuReceivedAt      DateTime?
  hdeuRawPayload      String?   @db.Text

  // Applicant info
  applicantId     String
  applicant       User              @relation("Applicant", fields: [applicantId], references: [id])

  // HDAB staff
  caseHandlerId   String?
  caseHandler     User?             @relation("CaseHandler", fields: [caseHandlerId], references: [id])

  // Application form fields (EHDS common data access application form)
  title                 String
  projectDescription    String            @db.Text
  purposeCategory       String
  requestedDatasets     String[]
  requestedVariables    String            @db.Text
  studyPopulation       String            @db.Text
  inclusionCriteria     String            @db.Text
  exclusionCriteria     String            @db.Text
  dataStartDate         DateTime?
  dataEndDate           DateTime?
  projectStartDate      DateTime?
  projectEndDate        DateTime?
  legalBasis            String
  dataProcessingCountry String
  isCrossBorder         Boolean           @default(false)

  // Statutory deadlines (EHDS Reg. Art. 46)
  submittedAt           DateTime?
  decisionDeadline      DateTime?         // submitted + 2 months (extendable to 4)
  deadlineExtended      Boolean           @default(false)
  // Deadline for applicant to respond to AWAITING_ADDITIONAL_INFORMATION
  additionalInfoDeadline DateTime?

  // Decision
  decisionAt            DateTime?
  decisionSummary       String?           @db.Text
  permitNumber          String?           @unique
  permitValidFrom       DateTime?
  permitValidUntil      DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs    AuditLog[]
  notes        Note[]
  documents    Document[]
}

model AuditLog {
  id            String             @id @default(cuid())
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id])
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  action        String
  comment       String?            @db.Text
  createdAt     DateTime           @default(now())
}

model Note {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  authorId      String
  author        User        @relation(fields: [authorId], references: [id])
  content       String      @db.Text
  isInternal    Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model Document {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  filename      String
  mimeType      String
  sizeBytes     Int
  uploadedAt    DateTime    @default(now())
  description   String?
}
