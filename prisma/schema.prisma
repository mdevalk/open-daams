generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationType {
  DATA_ACCESS_APPLICATION
  DATA_REQUEST
}

// TEHDAS2 D6.4 Section 7.6 / 7.7 — identical for both application types
enum ApplicationStatus {
  DRAFT
  SUBMITTED
  PRE_SCREENING
  AWAITING_ADDITIONAL_INFORMATION
  PROCESSING
  DECISION_ISSUED
  WITHDRAWN
}

// TEHDAS2 D6.4 Section 9 — sub-state of DECISION_ISSUED
enum DecisionOutcome {
  POSITIVE
  NEGATIVE
}

// TEHDAS2 D6.4 Section 9.1 — optional step between positive decision and permit issuance
enum PermitAcceptanceStatus {
  PENDING // Conditions sent to applicant, awaiting confirmation
  ACCEPTED // Applicant confirmed — proceed to issue permit
  DECLINED // Applicant declined — application treated as withdrawn
}

// TEHDAS2 D6.3 §6.5 / EHDS Art. 62 — cost estimate sent to the applicant
// during assessment, before a decision is made
enum FeeEstimateStatus {
  PENDING // Sent to applicant, awaiting confirmation
  ACCEPTED // Applicant confirmed — assessment continues
  REJECTED // Applicant did not accept — application may be withdrawn/scoped down
}

// TEHDAS2 D6.4 Section 9.2
enum DataPermitStatus {
  GRANTED
  AMENDED
  RENEWED
  REVOKED
  EXPIRED
}

// TEHDAS2 D6.3 §6.1 — ethical review referenced in the application assessment
// (required where member state law mandates it for the type of project)
enum EthicalReviewStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

// EHDS Art. 63 / national administrative law — appeal (bezwaar) and further
// judicial appeal (beroep) against a decision issued by the HDAB
enum AppealStatus {
  SUBMITTED
  UNDER_REVIEW
  UPHELD // Appeal successful — original decision revised
  REJECTED // Appeal rejected — original decision stands
  WITHDRAWN
}

// TEHDAS2 D6.3 §5.5 — outcome of the completeness check
enum CompletenessResult {
  PENDING
  COMPLETE
  INCOMPLETE
}

// TEHDAS2 D6.3 §7.1 / EHDS Art. 60, 68(7) — extraction request lifecycle
// between the HDAB and a health data holder
enum ExtractionStatus {
  REQUESTED
  CONFIRMED
  DELIVERED
  DECLINED
}

// TEHDAS2 D6.3 Annex 5 §6.1 — how the study cohort was/will be formed
// (data access applications only; not applicable to data requests)
enum CohortFormationMethod {
  CRITERIA // formed based on the criteria given in this application
  PREVIOUS_COHORT // an already-established cohort
  COMBINED // combination of criteria and a previously established cohort
  WHOLE_POPULATION // the whole population of the indicated country/countries
}

// TEHDAS2 D6.3 Annex 5 §6.1 / Annex 6 §6.1 — cohort/dataset extraction method
// (shared by both application types)
enum ExtractionMethod {
  RANDOM_SAMPLE
  ALL_QUALIFYING
  OTHER_SAMPLE
}

// TEHDAS2 D6.3 Annex 5 §6.1 / Annex 6 §6.1 — how often data must be extracted
enum ExtractionFrequency {
  ONCE
  MULTIPLE_TIMES
}

// TEHDAS2 D6.3 Annex 5 §6.1 / Annex 6 §6.1 — interval between recurring
// extractions, when ExtractionFrequency is MULTIPLE_TIMES
enum ExtractionInterval {
  YEARLY
  HALF_YEARLY
  QUARTERLY
  OTHER
}

// TEHDAS2 D6.3 Annex 5 §8 — when the health data user needs access to start
// (data access applications only)
enum DataAccessTiming {
  AS_SOON_AS_POSSIBLE
  LATER
}

enum UserRole {
  APPLICANT
  CASE_HANDLER
  DECISION_MAKER
  DATA_HOLDER
  ADMIN
}

enum ApplicationSource {
  NATIONAL
  HDEU
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         UserRole
  organisation String
  createdAt    DateTime @default(now())

  applications       Application[]           @relation("Applicant")
  handledCases       Application[]           @relation("CaseHandler")
  auditLogs          AuditLog[]
  notes              Note[]
  permitActions      DataPermitLog[]
  completenessChecks CompletenessCheck[]
  extractionRequests DataExtractionRequest[]
  issuedInvoices     Invoice[]
  speProvisioningActions SpeProvisioningLog[]
}

model Application {
  id              String            @id @default(cuid())
  referenceNumber String            @unique
  type            ApplicationType
  status          ApplicationStatus @default(DRAFT)
  source          ApplicationSource @default(NATIONAL)

  // Sub-state of DECISION_ISSUED (D6.4 §9)
  decisionOutcome DecisionOutcome?
  decisionAt      DateTime?
  decisionSummary String?          @db.Text

  // Optional permit-pending-acceptance step (D6.4 §9.1, SHOULD)
  permitAcceptanceStatus PermitAcceptanceStatus?
  permitConditionsSentAt DateTime?
  permitAcceptedAt       DateTime?

  // HD@EU cross-border fields
  hdeuApplicationId  String?
  hdeuSendingCountry String?
  hdeuReceivedAt     DateTime?
  hdeuRawPayload     String?   @db.Text

  applicantId String
  applicant   User   @relation("Applicant", fields: [applicantId], references: [id])

  caseHandlerId String?
  caseHandler   User?   @relation("CaseHandler", fields: [caseHandlerId], references: [id])

  // EHDS common data access application form fields
  title                 String
  projectDescription    String    @db.Text
  purposeCategory       String
  requestedDatasets     String[]
  requestedVariables    String    @db.Text
  studyPopulation       String    @db.Text
  inclusionCriteria     String    @db.Text
  exclusionCriteria     String    @db.Text
  dataStartDate         DateTime?
  dataEndDate           DateTime?
  projectStartDate      DateTime?
  projectEndDate        DateTime?
  legalBasis            String
  dataProcessingCountry String
  isCrossBorder         Boolean   @default(false)

  // Cohort/dataset extraction (D6.3 Annex 5 §6.1 / Annex 6 §6.1 — shared)
  cohortSizeIsEstimate      Boolean?
  cohortSize                Int?
  cohortSizeJustification   String?              @db.Text
  extractionMethod          ExtractionMethod?
  sampleSize                String? // e.g. "100000 persons" or "50%"
  samplingMethodDescription String?              @db.Text
  extractionFrequency       ExtractionFrequency?
  extractionInterval        ExtractionInterval?
  extractionIntervalOther   String?
  extractionTimingNotes     String?              @db.Text

  // Opt-out exception mechanism (Annex 5 §8 / Annex 6 §6 — EHDS Art. 71(4))
  usesOptOutException          Boolean @default(false)
  optOutExceptionJustification String? @db.Text

  // Data access application only (Annex 5 §6.1–6.3, 7, 8) — null/unused for
  // DATA_REQUEST, where only anonymised aggregated statistics are returned
  cohortFormationMethod      CohortFormationMethod?
  dataSubjectsInformed       Boolean?
  dataSubjectsInformedDetail String?                @db.Text // "how" if informed, or "why not" if not
  includesControls           Boolean                @default(false)
  controlsDescription        String?                @db.Text
  includesRelatives          Boolean                @default(false)
  relativesDescription       String?                @db.Text
  otherDataToCombine         Boolean                @default(false)
  otherDataDescription       String?                @db.Text
  speName                    String?
  speTechnicalRequirements   String?                @db.Text
  dataAccessTiming           DataAccessTiming?
  dataAccessLaterDate        DateTime?
  transfersOutsideEuEea      Boolean                @default(false)
  transferCountries          String[]
  transferLegalBasis         String?                @db.Text
  dataController             String?
  lawfulnessOfProcessing     String[] // selected GDPR Art. 6(1) grounds, stored as codes

  // Data request only (Annex 6 §6) — the tabulation plan for compiling
  // anonymised aggregated statistics; not applicable to data access applications
  tabulationPlan String? @db.Text

  // Ethical review (D6.3 §6.1, required where member state law mandates it)
  ethicalReviewRequired  Boolean              @default(false)
  ethicalReviewStatus    EthicalReviewStatus?
  ethicalReviewBody      String? // name of the ethics committee/IRB
  ethicalReviewReference String? // approval reference/case number
  ethicalReviewDate      DateTime?

  // Statutory deadlines
  // D6.4 §8: voided when AWAITING_ADDITIONAL_INFORMATION, recalculated on return to PROCESSING
  submittedAt              DateTime?
  decisionDeadline         DateTime?
  deadlineExtended         Boolean   @default(false)
  additionalInfoDeadline   DateTime? // Applicant response window
  additionalInfoReceivedAt DateTime? // Recalculation anchor (D6.4 §8)

  // Public disclosure (Art. 57(1)(j)(ii), 58, 61(4), D6.3 §5.1/§7.11)
  publishedAt         DateTime? // application made public, without undue delay after reception
  decisionPublishedAt DateTime? // decision/permit made public (within 30 working days)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs          AuditLog[]
  notes              Note[]
  documents          Document[]
  dataPermit         DataPermit?
  feeEstimate        FeeEstimate?
  appeals            Appeal[]
  completenessCheck  CompletenessCheck?
  extractionRequests DataExtractionRequest[]
  invoices           Invoice[]
}

// TEHDAS2 D6.3 Ch. 5 / Annex 7-8 — structured completeness check preceding
// the substantive assessment (distinct from the assessment itself)
model CompletenessCheck {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])

  // [{ key: string, label: string, passed: boolean, comment?: string }]
  items  Json
  result CompletenessResult @default(PENDING)

  checkedById String?
  checkedBy   User?     @relation(fields: [checkedById], references: [id])
  checkedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// TEHDAS2 D6.3 §7.1 / EHDS Art. 60, 68(7) — request to a health data holder
// to extract the data covered by an issued permit, through to delivery
model DataExtractionRequest {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  dataHolderName     String
  datasetDescription String @db.Text

  requestedAt   DateTime @default(now())
  requestedById String
  requestedBy   User     @relation(fields: [requestedById], references: [id])

  status        ExtractionStatus @default(REQUESTED)
  deliveredAt   DateTime?
  deliveryNotes String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// EHDS Art. 63 / national administrative law — tracks bezwaar (objection) and
// beroep (judicial appeal) lodged against a decision issued on this
// application (or its permit, e.g. a revocation)
model Appeal {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  submittedAt DateTime @default(now())
  submittedBy String // name of the appellant (may differ from the applicant)
  grounds     String   @db.Text
  authority   String? // body handling the appeal, e.g. "HDAB-NL (bezwaar)" or "Rechtbank Den Haag"

  status          AppealStatus @default(SUBMITTED)
  decisionAt      DateTime?
  decisionSummary String?      @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// TEHDAS2 D6.3 §6.5 — cost estimate for data holder + HDAB processing fees,
// sent to the applicant for confirmation before assessment continues
// (EHDS Art. 62(5))
model FeeEstimate {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])
  currency      String      @default("EUR")

  administrativeFee  Decimal? @db.Decimal(10, 2) // processing/application management
  dataPreparationFee Decimal? @db.Decimal(10, 2) // anonymisation, pseudonymisation, etc.
  dataHolderFee      Decimal? @db.Decimal(10, 2) // fees charged by health data holder(s)
  totalAmount        Decimal  @db.Decimal(10, 2)

  notes  String?           @db.Text
  status FeeEstimateStatus @default(PENDING)

  sentAt      DateTime  @default(now())
  respondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice?
}

// TEHDAS2 D6.4 Section 9.2 — permit lifecycle, separate from application
model DataPermit {
  id            String           @id @default(cuid())
  permitNumber  String           @unique // e.g. DP-NL-2025-0001
  applicationId String           @unique
  application   Application      @relation(fields: [applicationId], references: [id])
  status        DataPermitStatus @default(GRANTED)

  validFrom  DateTime
  validUntil DateTime

  // Populated when AMENDED or RENEWED — new permit ID issued (D6.4 §9.2)
  previousPermitId String?

  revocationReason String?   @db.Text
  revocationAt     DateTime?

  // Fees for data permit and processing services (Annex 9 §7 / EHDS Art. 62)
  currency              String   @default("EUR")
  permitProcessingFee   Decimal? @db.Decimal(10, 2)
  dataPreparationFee    Decimal? @db.Decimal(10, 2)
  speSetupFee           Decimal? @db.Decimal(10, 2)
  speUsageFee           Decimal? @db.Decimal(10, 2)
  additionalServicesFee Decimal? @db.Decimal(10, 2)
  dataHolderFee         Decimal? @db.Decimal(10, 2)
  paymentTerms          String?  @db.Text

  issuedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs              DataPermitLog[]
  authorizedPersons AuthorizedPerson[]
  invoices          Invoice[]
  speProvisioning   SpeProvisioningOrder?
}

// EHDS Art. 73 / TEHDAS2 D6.4 §9 — provisioning of the secure processing
// environment (SPE) that authorized persons process the granted dataset in.
// Only applicable to DATA_ACCESS_APPLICATION permits (data requests return
// aggregated output and don't involve an SPE).
enum SpeProvisioningStatus {
  REQUESTED       // Provisioning requested from the SPE operator
  PROVISIONING    // Environment being set up
  ACTIVE          // Environment provisioned and in use
  DECOMMISSIONING // Decommission requested (e.g. permit revoked/expired)
  DECOMMISSIONED
}

model SpeProvisioningOrder {
  id       String                @id @default(cuid())
  permitId String                @unique
  permit   DataPermit            @relation(fields: [permitId], references: [id])
  status   SpeProvisioningStatus @default(REQUESTED)

  // Reference/URL into the actual SPE operator's system, once known
  environmentReference String?

  requestedAt      DateTime  @default(now())
  provisionedAt    DateTime?
  decommissionedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs SpeProvisioningLog[]
}

model SpeProvisioningLog {
  id         String                 @id @default(cuid())
  orderId    String
  order      SpeProvisioningOrder   @relation(fields: [orderId], references: [id])
  userId     String
  user       User                   @relation(fields: [userId], references: [id])
  fromStatus SpeProvisioningStatus?
  toStatus   SpeProvisioningStatus
  comment    String?                @db.Text
  createdAt  DateTime               @default(now())
}

// EHDS Art. 62 / TEHDAS2 D6.3 Ch. 8 — invoicing of fees.
//
// A provisional invoice may be issued from an accepted FeeEstimate while the
// application is still under assessment (no permit exists yet); its line
// items are a snapshot of the estimate's fee breakdown. Once a permit is
// granted, a final (non-provisional) invoice is issued from the permit's own
// fee breakdown, which may differ (e.g. SPE fees only apply once granted).
enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique // e.g. INV-NL-2026-0001
  provisional   Boolean       @default(false)

  // Set once a permit exists (final invoice)
  permitId String?
  permit   DataPermit? @relation(fields: [permitId], references: [id])

  // Set for a provisional invoice, issued directly from the accepted
  // fee estimate before a permit exists
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id])
  feeEstimateId String?      @unique
  feeEstimate   FeeEstimate? @relation(fields: [feeEstimateId], references: [id])

  currency    String        @default("EUR")
  lineItems   Json // [{ description: string, amount: string }]
  totalAmount Decimal       @db.Decimal(10, 2)
  status      InvoiceStatus @default(ISSUED)

  issuedAt DateTime  @default(now())
  dueAt    DateTime
  paidAt   DateTime?

  notes String? @db.Text

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Annex 9 §6.8 — persons entitled to process the data granted under this
// permit within the secure processing environment (SPE)
model AuthorizedPerson {
  id          String     @id @default(cuid())
  permitId    String
  permit      DataPermit @relation(fields: [permitId], references: [id])
  name        String
  affiliation String
  email       String
  addedAt     DateTime   @default(now())
}

// Immutable audit log for the permit lifecycle
model DataPermitLog {
  id         String            @id @default(cuid())
  permitId   String
  permit     DataPermit        @relation(fields: [permitId], references: [id])
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  fromStatus DataPermitStatus?
  toStatus   DataPermitStatus
  action     String
  comment    String?           @db.Text
  createdAt  DateTime          @default(now())
}

model AuditLog {
  id            String             @id @default(cuid())
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id])
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  action        String
  comment       String?            @db.Text
  createdAt     DateTime           @default(now())
}

model Note {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  authorId      String
  author        User        @relation(fields: [authorId], references: [id])
  content       String      @db.Text
  isInternal    Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model Document {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  filename      String
  mimeType      String
  sizeBytes     Int
  uploadedAt    DateTime    @default(now())
  description   String?
}
